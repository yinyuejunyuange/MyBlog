<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.oyyj.studyservice.mapper.ChatMessageMapper">

    <select id="listUserHistory" resultType="org.oyyj.studyservice.vo.chatMessage.ChatMessageVO">

        SELECT knowledge_point_name,session_id,create_time FROM chat_message
        WHERE sort = 1 AND is_finish =1
        <if test="userId != null">
            AND user_id = #{userId}
        </if>

    </select>
</mapper>
